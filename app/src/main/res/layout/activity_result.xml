<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Compilazione completata"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvQuestionnaireName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#6B7280"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:id="@+id/tvScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="64sp"
            android:textStyle="bold"
            android:textColor="#1D9E75"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvMaxScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="#6B7280"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:id="@+id/tvInterpretation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:gravity="center"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Il medico vedrà questi risultati durante la visita"
            android:textSize="12sp"
            android:textColor="#9CA3AF"
            android:gravity="center"
            android:layout_marginBottom="32dp"/>

        <Button
            android:id="@+id/btnFinish"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Torna all'inizio"
            android:backgroundTint="#1D9E75"
            android:textColor="#FFFFFF"
            android:padding="16dp"/>

    </LinearLayout>
</ScrollView>